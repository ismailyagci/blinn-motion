{
  "name": "@blinn-motion/core",
  "version": "0.1.3",
  "description": "Blinn Motion core \u2014 pure, DOM-free render engine. Samples a MotionDoc at time t into a backend-agnostic resolved render tree. Shared by every adapter.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "SCHEMA.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailyagci/blinn-motion.git",
    "directory": "packages/core"
  },
  "homepage": "https://docs.blinnmotion.com/concepts/render-engine",
  "bugs": {
    "url": "https://github.com/ismailyagci/blinn-motion/issues"
  },
  "keywords": [
    "blinn-motion",
    "figma",
    "figma-motion",
    "motiondoc",
    "animation",
    "motion",
    "timeline",
    "render-engine",
    "sampler",
    "easing"
  ]
}
