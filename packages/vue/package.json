{
  "name": "@blinn-motion/vue",
  "version": "0.1.0",
  "description": "Blinn Motion Vue adapter — <BlinnMotion/> component and useBlinnMotion() composable for DOM/Canvas backends.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "@blinn-motion/core": "^0.1.0",
    "@blinn-motion/dom": "^0.1.0",
    "@blinn-motion/canvas": "^0.1.0"
  },
  "devDependencies": {
    "vue": "^3.5.13"
  }
}
