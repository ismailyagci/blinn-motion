{
  "name": "@fottie/canvas",
  "version": "0.1.0",
  "description": "Fottie Canvas adapter — paints @fottie/core's resolved render tree onto a 2D canvas. Pure JS, no DOM layout.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fottie/core": "^0.1.0"
  }
}
