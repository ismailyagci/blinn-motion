{
  "name": "@blinn-motion/canvas",
  "version": "0.1.1",
  "description": "Blinn Motion Canvas adapter \u2014 paints @blinn-motion/core's resolved render tree onto a 2D canvas. Pure JS, no DOM layout.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blinn-motion/core": "^0.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailyagci/blinn-motion.git"
  },
  "homepage": "https://blinnmotion.com",
  "bugs": {
    "url": "https://github.com/ismailyagci/blinn-motion/issues"
  }
}
