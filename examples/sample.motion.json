{
  "format": "motion-engine",
  "version": "1.0",
  "meta": { "name": "Card intro (hand-authored sample)", "source": "manual" },
  "duration": 1.6,
  "fps": 60,
  "stage": { "width": 375, "height": 600, "background": "#0E1116FF" },
  "layers": [
    {
      "id": "card",
      "name": "Card",
      "type": "rect",
      "base": {
        "x": 44, "y": 200, "width": 287, "height": 200,
        "opacity": 1, "rotation": 0, "scaleX": 1, "scaleY": 1,
        "anchor": { "x": 0.5, "y": 0.5 },
        "cornerRadius": [24, 24, 24, 24],
        "fill": { "type": "linear", "angle": 135, "stops": [
          { "pos": 0, "color": "#3B82F6FF" },
          { "pos": 1, "color": "#8B5CF6FF" }
        ] },
        "clip": false
      },
      "tracks": [
        { "property": "opacity", "op": "set", "unit": "none", "base": 1, "keys": [
          { "t": 0.0, "v": 0, "easing": { "type": "cubicBezier", "p": [0, 0, 0.58, 1] } },
          { "t": 0.45, "v": 1, "easing": { "type": "hold" } }
        ] },
        { "property": "translateY", "op": "offset", "unit": "px", "base": 0, "keys": [
          { "t": 0.0, "v": 80, "easing": { "type": "spring", "bounce": 0.45 } },
          { "t": 0.8, "v": 0, "easing": { "type": "hold" } }
        ] },
        { "property": "scaleXY", "op": "set", "unit": "ratio", "base": 1, "keys": [
          { "t": 0.0, "v": [0.7, 0.7], "easing": { "type": "spring", "bounce": 0.55 } },
          { "t": 0.8, "v": [1, 1], "easing": { "type": "hold" } }
        ] }
      ],
      "children": [
        {
          "id": "badge",
          "name": "Badge",
          "type": "ellipse",
          "base": {
            "x": 24, "y": 24, "width": 56, "height": 56,
            "opacity": 1, "rotation": 0, "scaleX": 1, "scaleY": 1,
            "anchor": { "x": 0.5, "y": 0.5 },
            "cornerRadius": [28, 28, 28, 28],
            "fill": { "type": "solid", "color": "#FACC15FF" }
          },
          "tracks": [
            { "property": "rotation", "op": "offset", "unit": "deg", "base": 0, "keys": [
              { "t": 0.0, "v": 0, "easing": { "type": "linear" } },
              { "t": 1.6, "v": 360, "easing": { "type": "hold" } }
            ] },
            { "property": "scaleXY", "op": "set", "unit": "ratio", "base": 1, "keys": [
              { "t": 0.4, "v": [1, 1], "easing": { "type": "cubicBezier", "p": [0.42, 0, 0.58, 1] } },
              { "t": 0.7, "v": [1.25, 1.25], "easing": { "type": "cubicBezier", "p": [0.42, 0, 0.58, 1] } },
              { "t": 1.0, "v": [1, 1], "easing": { "type": "hold" } }
            ] },
            { "property": "fillColor", "op": "set", "unit": "none", "base": "#FACC15FF", "keys": [
              { "t": 0.4, "v": "#FACC15FF", "easing": { "type": "linear" } },
              { "t": 1.0, "v": "#22D3EEFF", "easing": { "type": "hold" } }
            ] }
          ]
        },
        {
          "id": "title",
          "name": "Title",
          "type": "text",
          "base": {
            "x": 24, "y": 110, "width": 239, "height": 40,
            "opacity": 1, "rotation": 0, "scaleX": 1, "scaleY": 1,
            "anchor": { "x": 0, "y": 0.5 },
            "text": { "characters": "Our own engine", "fontSize": 26, "fontFamily": "Inter",
                      "fontWeight": 700, "color": "#FFFFFFFF", "lineHeight": 1.2,
                      "letterSpacing": 0, "align": "left" }
          },
          "tracks": [
            { "property": "opacity", "op": "set", "unit": "none", "base": 1, "keys": [
              { "t": 0.5, "v": 0, "easing": { "type": "cubicBezier", "p": [0, 0, 0.58, 1] } },
              { "t": 0.9, "v": 1, "easing": { "type": "hold" } }
            ] },
            { "property": "translateX", "op": "offset", "unit": "px", "base": 0, "keys": [
              { "t": 0.5, "v": -24, "easing": { "type": "cubicBezier", "p": [0.16, 1, 0.3, 1] } },
              { "t": 0.95, "v": 0, "easing": { "type": "hold" } }
            ] }
          ]
        }
      ]
    }
  ]
}
