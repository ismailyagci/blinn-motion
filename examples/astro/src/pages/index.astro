---
import "../styles/demo.css";
import { ReactIsland } from "../components/ReactIsland";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blinn Motion · Astro lab</title>
    <meta
      name="description"
      content="Blinn Motion Astro islands demo — React + Lit adapters sharing MotionDocs on dual stages."
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0B0D12" />
    <meta name="author" content="Blinn Motion" />
    <link rel="canonical" href="https://astro.blinnmotion.com/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Blinn Motion" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content="https://astro.blinnmotion.com/" />
    <meta property="og:title" content="Blinn Motion · Astro lab" />
    <meta
      property="og:description"
      content="Blinn Motion Astro islands demo — React + Lit adapters sharing MotionDocs on dual stages."
    />
    <meta property="og:image" content="https://astro.blinnmotion.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Blinn Motion Astro example lab" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Blinn Motion · Astro lab" />
    <meta
      name="twitter:description"
      content="Blinn Motion Astro islands demo — React + Lit adapters sharing MotionDocs on dual stages."
    />
    <meta name="twitter:image" content="https://astro.blinnmotion.com/og.png" />
  </head>
  <body>
    <div class="demo">
      <div class="stack-badge">Astro islands · React + Lit adapters</div>
      <h1>Blinn Motion · Astro advanced demo</h1>
      <p class="lede">
        Static Astro shell with client islands: a <strong>React</strong> dual-stage panel
        (<code>@blinn-motion/react</code>) and a <strong>Lit</strong> dual-stage panel
        (<code>@blinn-motion/lit</code>). No separate Astro runtime package — islands use existing adapters.
      </p>

      <section style="margin-bottom: 28px">
        <h2 style="font-size: 16px; margin: 0 0 12px">React island (client:load)</h2>
        <ReactIsland client:load />
      </section>

      <section>
        <h2 style="font-size: 16px; margin: 0 0 12px">Lit island (client:load)</h2>
        <div id="lit-root"></div>
      </section>

      <div id="snippet-host"></div>
    </div>
    <script>
      import { mountLitIsland } from "../scripts/mount-lit";
      import { mountSnippetPanel } from "../../../_shared/snippet-panel";
      mountLitIsland(document.getElementById("lit-root")!);
      const snip = document.getElementById("snippet-host");
      if (snip) mountSnippetPanel(snip, "astro");
    </script>
  </body>
</html>
