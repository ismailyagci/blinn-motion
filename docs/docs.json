{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Blinn Motion",
  "description": "The runtime for Figma Motion. MotionDoc → pure-JS engine → DOM · Canvas · React · Vue · Svelte · Angular · Lit · React Native.",
  "colors": {
    "primary": "#2F6BFF",
    "light": "#7AA0FF",
    "dark": "#2F6BFF"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": { "family": "Space Grotesk", "weight": 700 },
    "body": { "family": "Inter" }
  },
  "thumbnails": {
    "background": "/images/og-background.png"
  },
  "seo": {
    "metatags": {
      "og:site_name": "Blinn Motion",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "theme-color": "#2F6BFF",
      "application-name": "Blinn Motion",
      "keywords": "Blinn Motion, Figma Motion, Figma Motion to code, MotionDoc, animation runtime, Figma to code, Lottie alternative, React animation, Canvas animation, React Native animation"
    },
    "organization": {
      "name": "Blinn Motion",
      "url": "https://docs.blinnmotion.com",
      "logo": "https://docs.blinnmotion.com/logo/light.svg",
      "sameAs": [
        "https://github.com/ismailyagci/blinn-motion",
        "https://www.npmjs.com/org/blinn-motion",
        "https://blinnmotion.com"
      ]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/motiondoc",
              "concepts/render-engine",
              "concepts/easing"
            ]
          },
          {
            "group": "Adapters",
            "pages": [
              "adapters/overview",
              "adapters/dom",
              "adapters/canvas",
              "adapters/react",
              "adapters/vue",
              "adapters/svelte",
              "adapters/angular",
              "adapters/lit",
              "adapters/react-native"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/figma-plugin",
              "guides/figma-motion-to-react",
              "guides/playback"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/motiondoc-schema",
              "reference/core-api",
              "reference/figma-coverage"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "Live demo", "href": "https://blinnmotion.com" },
      { "label": "Examples", "href": "https://blinnmotion.com/#examples" }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/ismailyagci/blinn-motion"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ismailyagci/blinn-motion"
    }
  }
}
