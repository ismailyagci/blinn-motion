---
const rows = [
  { a: "Source of truth", hand: "Rebuilt from handoff", video: "Baked export", blinn: "Figma Motion timeline" },
  { a: "Timing & springs", hand: "Approximate in CSS/JS", video: "Locked in pixels", blinn: "Same keyframes & easings" },
  { a: "Interactive", hand: "Yes — if you code it", video: "Play-only media", blinn: "Play · seek · scrub · rate" },
  { a: "Platforms", hand: "Usually web-only", video: "Anywhere as a file", blinn: "DOM · Canvas · React · Vue · Svelte · Angular · Lit · RN" },
  { a: "Git / PR review", hand: "Diff the hand-written code", video: "Binary blob", blinn: "Diffable MotionDoc JSON" },
  { a: "Designer → eng", hand: "Spec + rebuild", video: "Drop a file", blinn: "Same file ships" },
];
---

<section class="section section-alt" id="compare">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="eyebrow"><span class="kf"></span> When motion lives in Figma</span>
      <h2 class="title">Ship the timeline.<br />Skip the detour.</h2>
      <p class="lead">Product teams already animate in Figma — then rebuild in CSS, export a video, or leave
        for another tool. Blinn is the runtime for motion that already lives in Figma.</p>
    </div>

    <div class="compare card" data-reveal>
      <div class="compare-head">
        <span class="ch-aspect"></span>
        <span class="ch-alt mono">Hand CSS / JS</span>
        <span class="ch-alt mono">Video / GIF</span>
        <span class="ch-blinn-motion">
          <span class="ch-logo" aria-hidden="true">
            <svg viewBox="0 0 64 64" width="17" height="17"><rect x="6" y="6" width="52" height="52" rx="15" fill="#11141A"/><g fill="none" stroke="#fff" stroke-width="6.2" stroke-linecap="round" stroke-linejoin="round"><path d="M24 18 V46"/><path d="M24 18 H32.5 C38.6 18 38.6 32 32.5 32 H24"/><path d="M24 32 H34.5 C41.2 32 41.2 46 34.5 46 H24"/></g><rect x="43.6" y="43.6" width="7.6" height="7.6" rx="1.5" transform="rotate(45 47.4 47.4)" fill="#2F6BFF"/></svg>
          </span>
          Blinn Motion
        </span>
      </div>
      {rows.map((r, i) => (
        <div class="compare-row" data-reveal style={`--reveal-delay:${i * 45}ms`}>
          <span class="cr-aspect">{r.a}</span>
          <span class="cr-alt">{r.hand}</span>
          <span class="cr-alt">{r.video}</span>
          <span class="cr-blinn-motion">
            <svg class="cr-check" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
            {r.blinn}
          </span>
        </div>
      ))}
    </div>

    <p class="compare-note" data-reveal>
      Blinn Motion is the runtime for <strong>Figma Motion</strong> — not a rebuild of another motion format.
      MIT-licensed and independent.
    </p>
  </div>
</section>

<style>
  .compare { padding: 0; overflow: hidden; max-width: 100%; min-width: 0; }
  .compare-head, .compare-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr) minmax(0, 1.05fr) minmax(0, 1.35fr);
    align-items: center;
    gap: 14px;
    padding: 15px 22px;
    min-width: 0;
  }
  .compare-head { background: var(--paper-2); border-bottom: 1px solid var(--line); font-size: 13px; font-weight: 600; }
  .ch-alt { color: var(--ink-3); font-weight: 500; }
  .ch-blinn-motion { display: inline-flex; align-items: center; gap: 8px; color: var(--ink); font-family: var(--display); }
  .ch-logo { display: grid; place-items: center; }

  .compare-row { border-bottom: 1px solid var(--line); font-size: 14.5px; }
  .compare-row:last-child { border-bottom: 0; }
  .cr-aspect { color: var(--ink); font-weight: 600; }
  .cr-alt { color: var(--ink-3); }
  .cr-blinn-motion {
    display: inline-flex; align-items: center; gap: 9px;
    color: var(--ink); font-weight: 500;
    padding: 8px 14px; margin: -8px -8px -8px 0;
    border-radius: 10px; background: var(--blue-t);
  }
  .cr-check { flex: none; color: #0a8a5f; }

  .compare-note { text-align: center; color: var(--ink-3); font-size: 12.5px; margin-top: 20px; max-width: 560px; margin-inline: auto; line-height: 1.5; }

  @media (max-width: 900px) {
    .compare-head { display: none; }
    .compare-row { grid-template-columns: 1fr; gap: 6px; padding: 15px 18px; }
    .cr-aspect { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-3); font-weight: 500; }
    .cr-alt:nth-of-type(2)::before { content: "Hand CSS — "; color: var(--line-2); }
    .cr-alt:nth-of-type(3)::before { content: "Video — "; color: var(--line-2); }
    .cr-blinn-motion { margin: 4px 0 0; }
  }
</style>
