---
import { adapters, frameworkSvg } from "../data/frameworks";
---

<section class="section section-alt" id="adapters">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="eyebrow"><span class="kf"></span> Adapters</span>
      <h2 class="title">One document.<br />Every platform, frame for frame.</h2>
      <p class="lead">Every adapter paints the <em>same</em> resolved render tree, so an animation looks
        and <strong>times identically</strong> wherever it runs. The adapters are thin; the engine does the thinking.</p>
    </div>

    <div class="adapter-grid">
      {adapters.map((a, i) => (
        <article class="card adapter" data-reveal style={`--reveal-delay:${i * 50}ms; --c:${a.c}; --tint:${a.tint}`}>
          <div class="adapter-head">
            <span class="adapter-logo" set:html={frameworkSvg(a.id, 22)} />
            <div class="adapter-id">
              <h3 class="adapter-name">{a.name}</h3>
              <span class="adapter-pkg mono">{a.pkg}</span>
            </div>
            <span class="adapter-badge mono">{a.badge}</span>
          </div>
          <p class="adapter-desc">{a.desc}</p>
          <pre class="adapter-code mono"><code>{a.code}</code></pre>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .adapter-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .adapter { display: flex; flex-direction: column; }
  .adapter-head { display: flex; align-items: center; gap: 12px; margin-bottom: 15px; }
  .adapter-logo {
    width: 40px; height: 40px; border-radius: 11px; flex: none;
    display: grid; place-items: center;
    color: var(--c); background: var(--tint);
    border: 1px solid color-mix(in srgb, var(--c) 22%, transparent);
  }
  .adapter-logo :global(svg) { display: block; }
  .adapter-id { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .adapter-name { font-size: 18px; letter-spacing: -0.02em; line-height: 1.1; }
  .adapter-pkg { font-size: 12px; color: var(--ink-3); }
  .adapter-badge {
    margin-left: auto; font-size: 11px; color: var(--ink-2);
    padding: 5px 10px; border-radius: 999px; background: var(--tint); white-space: nowrap;
  }
  .adapter-desc { color: var(--ink-2); font-size: 14.5px; line-height: 1.55; margin: 0 0 16px; flex: 1; }
  .adapter-code {
    margin: 0; padding: 14px 15px; background: var(--paper-2);
    border: 1px solid var(--line); border-radius: var(--r-sm);
    font-size: 12.5px; line-height: 1.6; color: var(--ink-2); overflow-x: auto; white-space: pre;
  }
  @media (max-width: 900px) {
    .adapter-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 760px) {
    .adapter-badge { display: none; }
  }
</style>
